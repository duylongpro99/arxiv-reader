# .env.example — copy to .env, then fill in.  `cp .env.example .env`
# .env is gitignored and MUST NEVER be committed.
#
# Every value in config.yaml can be overridden here (env vars win over YAML),
# so a deployment can retune without a rebuild. Env names are SECTION_FIELD in
# screaming snake case. Numeric overrides that don't parse fail fast at startup.

# REQUIRED. API key for your LLM provider. Read only from .env; never logged.
LLM_API_KEY=your_key_here

# OPTIONAL — uncomment to override config.yaml defaults.

# --- LLM ---
# LLM_PROVIDER=anthropic                 # anthropic | openai | gemini
# LLM_MODEL=claude-sonnet-4-6
# LLM_BASE_URL=https://your-host/v1      # custom OpenAI-compatible endpoint (use with LLM_PROVIDER=openai)
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.3
# LLM_REQUEST_TIMEOUT_SECONDS=120

# --- Paths ---
# OBSIDIAN_VAULT_PATH=/absolute/path/to/your/obsidian/vault
# LOG_FILE=~/.arxiv-agent/processed.json

# --- Agent (discovery pipeline) ---
# AGENT_ARXIV_CATEGORY=cs.AI
# AGENT_ARXIV_BASE_URL=https://export.arxiv.org/api/query
# AGENT_FETCH_LIMIT=20
# AGENT_DISPLAY_LIMIT=5
# AGENT_USER_AGENT=arxiv-explainer-agent/1.0
# AGENT_REQUEST_TIMEOUT_SECONDS=10
# AGENT_MIN_REQUEST_INTERVAL_SECONDS=3
# AGENT_MAX_RETRIES=3
# AGENT_ARXIV_HTML_BASE_URL=https://arxiv.org/html
# AGENT_MAX_CONTENT_BYTES=52428800
# AGENT_MAX_REVIEW_ITERATIONS=2
